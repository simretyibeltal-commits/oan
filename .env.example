# ─── LLM PROVIDER ─────────────────────────────────────────────
# Supported: ollama | vllm | openai
LLM_PROVIDER=ollama
LLM_MODEL_NAME=qwen2.5:7b

# Ollama (LOCAL, recommended)
# Install: https://ollama.ai  |  Pull model: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434       # Used by router.py (native Ollama API)
OPENAI_BASE_URL=http://localhost:11434/v1   # Used by FastGeminiService (OpenAI-compat /v1)

# vLLM (self-hosted GPU server)
# LLM_PROVIDER=vllm
# LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# INFERENCE_ENDPOINT_URL=http://your-server:8000/v1
# INFERENCE_API_KEY=your_key_or_empty

# OpenAI-compatible cloud (e.g. Groq, Together AI)
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=llama-3.1-8b-instant
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=your_api_key

# ─── VOICE PIPELINE STT ───────────────────────────────────────
# Supported: faster_whisper
STT_PROVIDER=faster_whisper

# omniASR wrapper (recommended for Amharic — best WER/CER on KYAGABA dataset)
# Point FASTER_WHISPER_URL at the omniASR wrapper on port 8001 to use it.
# The main app uses the same OpenAI-compatible endpoint — no code changes needed.
FASTER_WHISPER_URL=http://localhost:8001   # omniASR wrapper
OMNIASR_MODEL=omniASR_LLM_7B_v2           # GPU: 17GB+ VRAM (A100/L4/H100 preferred; T4 16GB is tight)
# OMNIASR_MODEL=omniASR_CTC_300M_v2       # CPU fallback: ~4-6GB RAM, lower accuracy

# Original faster-whisper-server (port 8000 — still works if you prefer it)
# FASTER_WHISPER_URL=http://localhost:8000
# FASTER_WHISPER_MODEL=Systran/faster-whisper-medium

# ─── VOICE PIPELINE TTS ───────────────────────────────────────
# Supported: coqui_xtts
TTS_PROVIDER=coqui_xtts
XTTS_URL=http://localhost:8020
XTTS_SPEAKER_WAV=/path/to/reference_voice.wav   # 3-10s reference audio for voice cloning

# ─── TOOL CALLING NOTE ────────────────────────────────────────
# Not all models support function/tool calling. Recommended:
# Ollama: qwen2.5:7b, qwen2.5:14b, llama3.1:8b, mistral-nemo
# vLLM:   Qwen/Qwen2.5-7B-Instruct, meta-llama/Llama-3.1-8B-Instruct
# Groq:   llama-3.1-8b-instant, llama-3.3-70b-versatile

# ─── OTHER SERVICES (unchanged) ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/load_agri
MEITY_API_KEY_VALUE=your_bhashini_api_key
MARQO_ENDPOINT_URL=your_marqo_endpoint_url_here
MARQO_INDEX_NAME=your_marqo_index_name_here
ENABLE_MODERATION=false

# PostgreSQL Database Configuration
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
